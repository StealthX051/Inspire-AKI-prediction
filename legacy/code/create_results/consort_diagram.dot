digraph consort_flow {
    graph [rankdir=TB, splines=true, nodesep=0.5, ranksep=1.2];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=12, fillcolor="white"];
    edge [fontname="Arial", fontsize=10, arrowhead=normal, dir=forward];

    N0 [label=<Total operations recorded<BR/><B>(n=130,960)</B>>];
    N1 [label=<Operations after excluding unrecorded start/end time<BR/><B>(n=127,304)</B>>];
    N2 [label=<Operations after excluding unrecorded height/weight<BR/><B>(n=125,539)</B>>];
    N3 [label=<Operations after excluding Regional antype<BR/><B>(n=125,382)</B>>];
    N4 [label=<Operations after excluding specific procedures<BR/><B>(n=122,548)</B>>];
    N5 [label=<Operations after excluding missing intraoperative variables<BR/><B>(n=122,520)</B>>];
    N6 [label=<Operations after excluding unrecorded preoperative creatinine<BR/><B>(n=120,732)</B>>];
    N7 [label=<Operations after excluding missing post-op outcome<BR/><B>(n=60,826)</B>>];
    N0 -> N1;
    X1 [label=<Excluded (n=3,656)<BR ALIGN="LEFT"/>- Unrecorded start/end time<BR ALIGN="LEFT"/>>, shape=plaintext];
    { rank=same; N1; X1 }
    N1 -> X1 [style=invis];

    N1 -> N2;
    X2 [label=<Excluded (n=1,765)<BR ALIGN="LEFT"/>- Unrecorded height/weight<BR ALIGN="LEFT"/>>, shape=plaintext];
    { rank=same; N2; X2 }
    N2 -> X2 [style=invis];

    N2 -> N3;
    X3 [label=<Excluded (n=157)<BR ALIGN="LEFT"/>- Regional antype<BR ALIGN="LEFT"/>>, shape=plaintext];
    { rank=same; N3; X3 }
    N3 -> X3 [style=invis];

    N3 -> N4;
    X4 [label=<Excluded (n=2,834)<BR ALIGN="LEFT"/>- Obstetric, Kidney Donor/Recipient, and AV Fistula procedures<BR ALIGN="LEFT"/>>, shape=plaintext];
    { rank=same; N4; X4 }
    N4 -> X4 [style=invis];

    N4 -> N5;
    X5 [label=<Excluded (n=28)<BR ALIGN="LEFT"/>- No recorded intraoperative variables<BR ALIGN="LEFT"/>>, shape=plaintext];
    { rank=same; N5; X5 }
    N5 -> X5 [style=invis];

    N5 -> N6;
    X6 [label=<Excluded (n=1,788)<BR ALIGN="LEFT"/>- Unrecorded preoperative creatinine<BR ALIGN="LEFT"/>>, shape=plaintext];
    { rank=same; N6; X6 }
    N6 -> X6 [style=invis];

    N6 -> N7;
    X7 [label=<Excluded (n=59,906)<BR ALIGN="LEFT"/>- No post-op outcome (Cr at 2d/7d or Dialysis)<BR ALIGN="LEFT"/>>, shape=plaintext];
    { rank=same; N7; X7 }
    N7 -> X7 [style=invis];

    N_neg [label=<Final Cohort: Negative AKI Cases<BR/>(n=58,101)>];
    N_pos [label=<Final Cohort: Positive AKI Cases<BR/>(n=2,725)>];
    N7 -> N_neg [label="Negative AKI"];
    N7 -> N_pos [label="Positive AKI"];
    { rank=same; N_neg; N_pos; }

}